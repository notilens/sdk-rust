[package]
name = "notilens"
version = "0.3.0"
edition = "2021"
description = "NotiLens SDK — task lifecycle notifications for AI agents and background jobs"
repository = "https://github.com/notilens/sdk-rust"
license = "MIT"
keywords = ["notifications", "agents", "monitoring", "ai"]
categories = ["api-bindings"]

[lib]
name = "notilens"
path = "src/lib.rs"

[[bin]]
name = "notilens"
path = "src/bin/notilens.rs"

[dependencies]
serde      = { version = "1", features = ["derive"] }
serde_json = "1"
ureq       = "2"
